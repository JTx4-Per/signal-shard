# Database
DATABASE_URL=sqlite+aiosqlite:///./email_intel.db

# ---- Microsoft Graph auth (pluggable) -------------------------------------
# AUTH_MODE selects how the Graph client acquires bearer tokens.
#   device    — MSAL public device-code flow with a well-known public client
#               ID (Azure CLI) when MS_GRAPH_CLIENT_ID is unset. No app
#               registration required. Default for tenants that block
#               self-service app registration.
#   msal_app  — MSAL public device-code flow using a user-supplied
#               MS_GRAPH_CLIENT_ID + MS_GRAPH_TENANT_ID. For the future case
#               where an IT-approved app registration is granted.
#               (No client-secret flow.)
#   static    — A pre-acquired bearer token from Graph Explorer or similar
#               tool. Useful for bootstrap testing; no refresh support.
AUTH_MODE=device

# Optional: override the default public client_id / tenant when AUTH_MODE=device.
# Required when AUTH_MODE=msal_app.
MS_GRAPH_CLIENT_ID=
MS_GRAPH_TENANT_ID=
MS_GRAPH_REDIRECT_URI=http://localhost:8000/auth/callback

# For AUTH_MODE=static — paste one or provide a path to a file containing one.
MS_GRAPH_STATIC_TOKEN=
MS_GRAPH_STATIC_TOKEN_PATH=

# Where the MSAL token cache lives on disk.
MS_GRAPH_TOKEN_STORE_PATH=.email_intel/tokens.json

# Classifier
LLM_PROVIDER=none
CLASSIFIER_RULE_VERSION=v1.0.0

# Reducer / lifecycle
REDUCER_VERSION=v1.0.0
SOFT_COMPLETE_WINDOW_DAYS=7
DONE_CATEGORY_POLICY=clear

# Observability
LOG_LEVEL=INFO
